{
  "name": "wordlettuce",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "package": "svelte-kit package",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --ignore-path ../../.gitignore --check . && eslint .",
    "find": "prettier --find-config-path .",
    "prepare": "svelte-kit sync",
    "ship": "wrangler deploy -c wrangler.jsonc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@eslint/js": "^10.0.1",
    "@lettuce-apps-packages/auth": "workspace:*",
    "@lettuce-apps-packages/svelte-common": "workspace:*",
    "@libsql/client": "^0.17.4",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "2.70.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/svelte-query": "^6.1.36",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "autoprefixer": "^10.5.4",
    "bits-ui": "^2.18.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "js-cookie": "^3.0.8",
    "ky": "^2.0.2",
    "postcss": "^8.5.19",
    "runed": "^0.37.1",
    "svelte": "5.56.6",
    "svelte-check": "^4.7.3",
    "svelte2tsx": "^0.7.58",
    "svoast": "^3.0.3",
    "tailwindcss": "^4.3.3",
    "tslib": "^2.8.1",
    "tsx": "^4.23.1",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.64.0",
    "valibot": "^1.4.2",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0",
