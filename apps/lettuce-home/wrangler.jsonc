{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lettuce-home",
  "compatibility_date": "2026-01-01",
  "compatibility_flags": ["nodejs_als", "nodejs_compat"],
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "directory": ".svelte-kit/cloudflare",
    "binding": "ASSETS",
  },
  "workers_dev": true,
  "preview_urls": true,
}
