{
  "name": "lettuce-home",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler dev --port 5173",
    "prepare": "pnpm run types && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "types": "wrangler types",
    "ship": "wrangler deploy -c wrangler.jsonc"
  },
  "devDependencies": {
    "@content-collections/core": "^0.15.2",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/vite": "^0.3.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@iconify/json": "^2.2.491",
    "@iconify/tailwind4": "^1.2.3",
    "@internationalized/date": "^3.12.2",
    "@lettuce-apps-packages/svelte-common": "workspace:*",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/enhanced-img": "^0.11.0",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26",
    "bits-ui": "^2.18.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.7.0",
    "ky": "^2.0.2",
    "mdsvex": "^0.12.7",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "runed": "^0.37.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "uuid": "^14.0.1",
    "valibot": "^1.4.1",
    "vite": "^8.1.0",
    "wrangler": "^4.104.0"
  }
}
